msgstr "نسيت كلمة المرور؟ لا مشكلة. سنرسل رابط إعادة تعيين آمناً إلى بريدك خلال ثوانٍ."

msgid "Secure one-time reset link"
msgstr "رابط إعادة تعيين آمن لمرة واحدة"

msgid "Expires in 24 hours"
msgstr "تنتهي صلاحيته خلال 24 ساعة"

msgid "Your data stays protected"
msgstr "بياناتك تبقى محمية"

msgid "Check Your Inbox"
msgstr "تفقّد بريدك الوارد"

msgid "If an account exists for that email, a reset link has been sent. Don't forget to check your spam folder."
msgstr "إذا وُجد حساب بهذا البريد، فقد أُرسل رابط إعادة التعيين. لا تنسَ التحقق من مجلد الرسائل غير المرغوبة."

msgid "Back to Sign In"
msgstr "العودة لتسجيل الدخول"

msgid "Forgot Password?"
msgstr "نسيت كلمة المرور؟"

msgid "Enter your email and we'll send you a reset link"
msgstr "أدخل بريدك الإلكتروني وسنرسل لك رابط إعادة التعيين"

msgid "Send Reset Link"
msgstr "إرسال رابط التعيين"

msgid "Remember your password?"
msgstr "تذكرت كلمة المرور؟"

msgid "Email Sent"
msgstr "تم إرسال البريد"

msgid "Check your<br>inbox."
msgstr "تفقّد<br>بريدك الوارد."

msgid "We've sent a password reset link. It should arrive within a minute — don't forget to check spam."
msgstr "أرسلنا رابط إعادة تعيين كلمة المرور. سيصل خلال دقيقة — لا تنسَ التحقق من الرسائل غير المرغوبة."

msgid "Reset link sent"
msgstr "أُرسل رابط إعادة التعيين"

msgid "Check spam if not received"
msgstr "تحقق من الرسائل غير المرغوبة إن لم يصل"

msgid "Check Your Inbox!"
msgstr "تفقّد بريدك الوارد!"

#, python-format
msgid "We've sent a password reset link to your email. Didn't get it? Check your spam folder or <a href=\"%(url)s\" class=\"auth-panel__retry-link\">try again</a>."
msgstr "أرسلنا رابط إعادة تعيين كلمة المرور إلى بريدك. لم يصلك؟ تحقق من الرسائل غير المرغوبة أو <a href=\"%(url)s\" class=\"auth-panel__retry-link\">حاول مجدداً</a>."

msgid "Set New Password"
msgstr "تعيين كلمة مرور جديدة"

msgid "Almost<br>there."
msgstr "أوشكت<br>على الانتهاء."

msgid "Choose a strong password to keep your Rentora account safe and secure."
msgstr "اختر كلمة مرور قوية لإبقاء حسابك في رينتورا آمناً."

msgid "Minimum 8 characters"
msgstr "8 أحرف على الأقل"

msgid "Mix letters & numbers"
msgstr "امزج الحروف والأرقام"

msgid "Choose a strong password for your account"
msgstr "اختر كلمة مرور قوية لحسابك"

msgid "New Password"
msgstr "كلمة المرور الجديدة"

msgid "Confirm New Password"
msgstr "تأكيد كلمة المرور الجديدة"

msgid "Re-enter your new password"
msgstr "أعد إدخال كلمة المرور الجديدة"

msgid "Reset Password"
msgstr "إعادة تعيين كلمة المرور"

msgid "Password Reset Complete"
msgstr "اكتملت إعادة تعيين كلمة المرور"

msgid "All Done"
msgstr "تم كل شيء"

msgid "You're back<br>in action."
msgstr "عدت<br>من جديد."

msgid "Your password has been updated. Sign in and continue browsing, listing, or booking tools."
msgstr "تم تحديث كلمة مرورك. سجّل الدخول وواصل التصفّح أو عرض الأدوات أو حجزها."

msgid "Password updated securely"
msgstr "حُدّثت كلمة المرور بأمان"

msgid "All sessions protected"
msgstr "جميع الجلسات محمية"

msgid "Ready to get back to renting"
msgstr "جاهز للعودة إلى الاستئجار"

msgid "Password Reset Complete!"
msgstr "اكتملت إعادة تعيين كلمة المرور!"

msgid "Your password has been updated successfully. You can now sign in with your new password."
msgstr "تم تحديث كلمة مرورك بنجاح. يمكنك الآن تسجيل الدخول بكلمة المرور الجديدة."

msgid "Go to Sign In"
msgstr "اذهب لتسجيل الدخول"
